# Database - Neon on Vercel injects DATABASE_URL; or set manually for local dev
# DATABASE_URL="postgresql://user:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require"

# NextAuth - Generate with: openssl rand -base64 32
AUTH_SECRET="your-secret-at-least-32-characters-long"
# AUTH_URL is auto-detected on Vercel, but you can set it manually if needed
# AUTH_URL="https://your-app.vercel.app"

# Scorer login (Credentials provider)
AUTH_CREDENTIALS_USERNAME="scorer"
AUTH_CREDENTIALS_PASSWORD="change-me-secure-password"

# Donate link (live score page) - e.g. JustGiving or Virgin Money Giving (public, used for QR)
# NEXT_PUBLIC_DONATE_URL="https://www.justgiving.com/your-page"

# McMillan logo on display (optional) - path or full URL, e.g. /mcmillan-logo.png
# NEXT_PUBLIC_MCMILLAN_LOGO_URL="/mcmillan-logo.png"

# Optional: browser TTS announces scores on the display page (set to 1 to enable)
# NEXT_PUBLIC_ANNOUNCE_SCORES=1
